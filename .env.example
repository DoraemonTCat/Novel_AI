# ╔══════════════════════════════════════════════╗
# ║        Novel AI — Environment Config         ║
# ╚══════════════════════════════════════════════╝

# === Google OAuth 2.0 ===
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# === JWT Security ===
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === AI Providers ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-2.5-flash
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3:8b

# === Database ===
POSTGRES_DB=novel_ai
POSTGRES_USER=novel_user
POSTGRES_PASSWORD=novel_pass_change_me
DATABASE_URL=postgresql+asyncpg://novel_user:novel_pass_change_me@postgres:5432/novel_ai

# === Redis ===
REDIS_URL=redis://redis:6379/0
REDIS_RATE_LIMIT_URL=redis://redis:6379/1

# === ChromaDB ===
CHROMA_HOST=http://chromadb:8000

# === Stable Diffusion (Optional) ===
SD_API_URL=http://stable-diffusion:7860

# === App Settings ===
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
